rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: Check if user is admin
    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/user/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper: Check if user owns the document
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // User profiles
    match /user/{userId} {
      allow read: if isAuth();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Products — public read, admin write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Categories — public read, admin write
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders — users can create and read own, admin can read/write all
    match /orders/{orderId} {
      allow read: if isAdmin() || (isAuth() && resource.data.userUid == request.auth.uid);
      allow create: if isAuth() && request.resource.data.userUid == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Nasiya (credit) — admin only
    match /nasiya/{nasiyaId} {
      allow read: if isAdmin() || (isAuth() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }

    // Stock receipts — admin only
    match /stockReceipts/{receiptId} {
      allow read, write: if isAdmin();
    }

    // Stock movements — admin only
    match /stockMovements/{movementId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
    }

    // Invoices — admin only
    match /invoices/{invoiceId} {
      allow read, write: if isAdmin();
    }

    // Telegram users — admin read/write, users can read own
    match /telegramUsers/{telegramUserId} {
      allow read: if isAdmin() || (isAuth() && resource.data.userUid == request.auth.uid);
      allow write: if isAdmin() || (isAuth() && request.resource.data.userUid == request.auth.uid);
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
